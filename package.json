{
  "name": "linuxdo-enhanced",
  "version": "8.24.1",
  "description": "A Tampermonkey userscript that enhances Linux.do with ad hiding, topic filtering, read-state styling, header search, theme adaptation, and WebDAV backup.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "linux-do",
    "tampermonkey",
    "userscript",
    "vite",
    "webdav"
  ],
  "scripts": {
    "dev": "vite",
    "syntax": "node scripts/check-syntax.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.mjs\" \"*.js\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.mjs\" \"*.js\" \"*.json\"",
    "check": "npm run syntax && npm run lint && npm run format:check && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "vite": "^5.0.0",
    "vite-plugin-monkey": "^4.0.0"
  }
}
